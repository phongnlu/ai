{
  "extends": "@repo/config/typescript/nextjs.json",
  "compilerOptions": {
    "outDir": ".next",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@repo/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@repo/types/*": [
        "../../packages/types/src/*"
      ],
      "@repo/api/*": [
        "../../packages/api/src/*"
      ]
    },
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
