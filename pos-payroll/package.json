{
  "name": "pos-payroll",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:seed": "turbo run db:seed --filter=@repo/api",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.3.0"
  },
  "pnpm": {
    "overrides": {
      "tamagui": "1.94.3",
      "@tamagui/core": "1.94.3",
      "@tamagui/config": "1.94.3",
      "@tamagui/themes": "1.94.3",
      "@tamagui/animations-moti": "1.94.3",
      "@tamagui/next-plugin": "1.94.3",
      "@tamagui/babel-plugin": "1.94.3",
      "react-native-reanimated": "3.10.1"
    }
  }
}
